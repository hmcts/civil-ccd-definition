{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>hmcts/.github:renovate-config",
    "local>hmcts/.github//renovate/automerge-all"
  ],
  "labels": [
    "dependencies"
  ],
  "automergeSchedule": ["after 8am and before 11am every weekday"],
  "schedule": ["after 8am and before 11am every weekday"],
  "rebaseWhen": "conflicted",
  "automergeStrategy": "squash",
  "prConcurrentLimit": 5,
  "helmv3": {
    "bumpVersion": "patch"
  },
  "lockFileMaintenance": {
    "enabled": true
  },
  "regexManagers": [
    {
      "fileMatch": [
        "^Dockerfile$"
      ],
      "matchStrings": [
        "datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\sARG .*?_VERSION=(?<currentValue>.*)\\s"
      ]
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "All non-major updates",
      "groupSlug": "all-non-major",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 2pm every weekday"]
    },
    {
      "matchManagers": ["helmv3"],
      "groupName": "Helm chart updates",
      "groupSlug": "helm-charts",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 4pm every weekday"]
    },
    {
      "matchPackageNames": ["@playwright/test", "playwright-core", "@axe-core/playwright"],
      "groupName": "Playwright",
      "groupSlug": "playwright",
      "automerge": false,
      "automergeType": "pr",
      "automergeSchedule": ["before 2pm every weekday"]
    },
    {
      "matchPackageNames": ["allure-playwright"],
      "enabled": false
    },
    {
      "matchPackagePatterns": ["^allure-"],
      "groupName": "Allure reporting",
      "groupSlug": "allure",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 4pm every weekday"]
    },
    {
      "matchPackageNames": ["eslint", "typescript-eslint"],
      "matchPackagePatterns": ["^@eslint/", "^@typescript-eslint/", "^eslint-"],
      "groupName": "ESLint",
      "groupSlug": "eslint",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 2pm every weekday"]
    },
    {
      "matchPackageNames": ["typescript"],
      "matchPackagePatterns": ["^@types/"],
      "groupName": "TypeScript",
      "groupSlug": "typescript",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 4pm every weekday"]
    },
    {
      "matchPackagePatterns": ["^org\\.junit\\.", "^org\\.slf4j:"],
      "groupName": "Java dependencies",
      "groupSlug": "java-deps",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 4pm every weekday"]
    },
    {
      "matchPackageNames": ["node", "gradle", "yarn"],
      "groupName": "Build tools",
      "groupSlug": "build-tools",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 4pm every weekday"]
    }
  ]
}
